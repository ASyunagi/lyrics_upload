  <body dur="03:14.940">
    <div begin="00:01.200" end="03:14.940">
      <p begin="00:01.200" end="00:03.830" ttm:agent="v1" itunes:key="L1"><span begin="00:01.200" end="00:01.280">絵</span><span begin="00:01.380" end="00:01.520">文</span><span begin="00:01.520" end="00:01.740">字</span><span begin="00:01.740" end="00:01.890">ば</span><span begin="00:01.890" end="00:02.070">か</span><span begin="00:02.070" end="00:02.240">り</span><span begin="00:02.240" end="00:02.430">で</span><span begin="00:02.430" end="00:02.930">頷</span><span begin="00:02.930" end="00:03.080">き</span><span begin="00:03.080" end="00:03.240">あ</span><span begin="00:03.240" end="00:03.390">お</span><span begin="00:03.390" end="00:03.630">う</span><span begin="00:03.630" end="00:03.830">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">就只用表情符号来互相点头附和吧</span><span ttm:role="x-roman">Emoji bakari de unazukiaou yo</span></p>
      <p begin="00:04.110" end="00:06.490" ttm:agent="v1" itunes:key="L2"><span begin="00:04.110" end="00:04.260">上</span><span begin="00:04.260" end="00:04.450">昇</span><span begin="00:04.450" end="00:04.620">中</span><span begin="00:04.620" end="00:04.720">の</span><span begin="00:04.720" end="00:04.810">記</span><span begin="00:04.810" end="00:04.980">号</span><span begin="00:04.980" end="00:05.160">が</span><span begin="00:05.310" end="00:05.490">今</span><span begin="00:05.490" end="00:05.640">も</span><span begin="00:05.640" end="00:05.820">鼓</span><span begin="00:05.820" end="00:05.920">動</span><span begin="00:05.920" end="00:06.060">を</span><span begin="00:06.060" end="00:06.150">止</span><span begin="00:06.150" end="00:06.230">め</span><span begin="00:06.230" end="00:06.320">る</span><span begin="00:06.320" end="00:06.490">の</span><span ttm:role="x-translation" xml:lang="zh-CN">正在上升的符号如今心也停止跳动了吗</span><span ttm:role="x-roman">Joushou chuu no kigou ga ima mo kodou o tomeru no</span></p>
      <p begin="00:06.830" end="00:09.080" ttm:agent="v1" itunes:key="L3"><span begin="00:06.830" end="00:07.170">単</span><span begin="00:07.170" end="00:07.530">純</span><span begin="00:07.530" end="00:07.700">だ</span><span begin="00:07.700" end="00:07.850">と</span><span begin="00:07.850" end="00:08.040">か</span><span begin="00:08.040" end="00:08.150">言</span><span begin="00:08.150" end="00:08.360">う</span><span begin="00:08.360" end="00:08.520">の</span><span begin="00:08.520" end="00:08.710">な</span><span begin="00:08.710" end="00:09.080">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">如果你要说这很简单的话</span><span ttm:role="x-roman">Tanjun da toka iu no nara</span></p>
      <p begin="00:09.370" end="00:11.930" ttm:agent="v1" itunes:key="L4"><span begin="00:09.370" end="00:09.690">今</span><span begin="00:09.690" end="00:09.910">す</span><span begin="00:09.910" end="00:10.030">ぐ</span><span begin="00:10.030" end="00:10.260">わ</span><span begin="00:10.260" end="00:10.430">か</span><span begin="00:10.430" end="00:10.590">り</span><span begin="00:10.590" end="00:10.750">や</span><span begin="00:10.750" end="00:10.940">す</span><span begin="00:10.940" end="00:11.040">く</span><span begin="00:11.040" end="00:11.410">教</span><span begin="00:11.410" end="00:11.620">え</span><span begin="00:11.620" end="00:11.780">て</span><span begin="00:11.780" end="00:11.930">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">现在立刻浅显易懂地告诉我吧</span><span ttm:role="x-roman">Ima sugu wakariyasuku oshiete yo</span></p>
      <p begin="00:12.280" end="00:13.860" ttm:agent="v1" itunes:key="L5"><span begin="00:12.280" end="00:12.630">今</span><span begin="00:12.630" end="00:12.960">何</span><span begin="00:12.960" end="00:13.150">し</span><span begin="00:13.150" end="00:13.320">て</span><span begin="00:13.320" end="00:13.490">ん</span><span begin="00:13.490" end="00:13.830">の</span><span begin="00:13.830" end="00:13.860">？</span><span ttm:role="x-translation" xml:lang="zh-CN">现在在做什么？</span><span ttm:role="x-roman">Ima nani shiten no?</span></p>
      <p begin="00:14.850" end="00:16.740" ttm:agent="v1" itunes:key="L6"><span begin="00:14.850" end="00:15.200">今</span><span begin="00:15.200" end="00:15.500">何</span><span begin="00:15.500" end="00:15.700">わ</span><span begin="00:15.700" end="00:15.850">か</span><span begin="00:15.850" end="00:16.040">っ</span><span begin="00:16.040" end="00:16.220">て</span><span begin="00:16.220" end="00:16.380">る</span><span begin="00:16.380" end="00:16.710">の</span><span begin="00:16.710" end="00:16.740">？</span><span ttm:role="x-translation" xml:lang="zh-CN">现在了解些什么？</span><span ttm:role="x-roman">Ima nani wakatteru no?</span></p>
      <p begin="00:16.870" end="00:19.460" ttm:agent="v1" itunes:key="L7"><span begin="00:16.870" end="00:17.060">わ</span><span begin="00:17.060" end="00:17.200">か</span><span begin="00:17.200" end="00:17.410">っ</span><span begin="00:17.410" end="00:17.600">て</span><span begin="00:17.600" end="00:17.770">る</span><span begin="00:17.770" end="00:17.940">な</span><span begin="00:17.940" end="00:18.040">ら</span><span begin="00:18.270" end="00:18.620">全</span><span begin="00:18.620" end="00:18.790">部</span><span begin="00:18.790" end="00:18.930">言</span><span begin="00:18.930" end="00:19.110">っ</span><span begin="00:19.110" end="00:19.290">て</span><span begin="00:19.290" end="00:19.460">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">如果了解的话就全部说出来吧</span><span ttm:role="x-roman">Wakatteru nara zenbu itte yo</span></p>
      <p begin="00:19.790" end="00:22.820" ttm:agent="v1" itunes:key="L8"><span begin="00:19.790" end="00:20.730">私</span><span begin="00:21.150" end="00:21.820">の</span><span begin="00:21.820" end="00:22.530">こ</span><span begin="00:22.530" end="00:22.820">と</span><span ttm:role="x-translation" xml:lang="zh-CN">关于我的事</span><span ttm:role="x-roman">Watashi no koto</span></p>
      <p begin="00:23.210" end="00:28.500" ttm:agent="v1" itunes:key="L9"><span begin="00:23.210" end="00:23.530">見</span><span begin="00:23.530" end="00:23.790">え</span><span begin="00:23.900" end="00:24.760">な</span><span begin="00:24.760" end="00:24.860">い</span><span begin="00:25.180" end="00:25.910">表</span><span begin="00:25.910" end="00:26.180">情</span><span begin="00:26.460" end="00:26.620">を</span><span begin="00:26.620" end="00:27.000">誤</span><span begin="00:27.130" end="00:27.290">魔</span><span begin="00:27.290" end="00:27.480">化</span><span begin="00:27.610" end="00:27.970">す</span><span begin="00:27.970" end="00:28.140">の</span><span begin="00:28.140" end="00:28.320">な</span><span begin="00:28.320" end="00:28.500">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">如果要掩饰看不见的表情的话</span><span ttm:role="x-roman">Mienai hyoujou o gomakasu no nara</span></p>
      <p begin="00:28.990" end="00:33.310" ttm:agent="v1" itunes:key="L10"><span begin="00:28.990" end="00:29.330">人</span><span begin="00:29.330" end="00:29.650">間</span><span begin="00:29.650" end="00:29.830">じゃ</span><span begin="00:29.830" end="00:30.040">な</span><span begin="00:30.040" end="00:30.150">い</span><span begin="00:30.150" end="00:30.350">っ</span><span begin="00:30.350" end="00:30.610">て</span><span begin="00:30.980" end="00:31.910">曝</span><span begin="00:31.910" end="00:32.080">け</span><span begin="00:32.080" end="00:32.520">出</span><span begin="00:32.520" end="00:32.740">し</span><span begin="00:32.740" end="00:32.990">ちゃ</span><span begin="00:32.990" end="00:33.110">う</span><span begin="00:33.110" end="00:33.310">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">我就会暴露自己不是人类哦</span><span ttm:role="x-roman">Ningen janai tte sarakedashichau yo</span></p>
      <p begin="00:33.750" end="00:35.060" ttm:agent="v1" itunes:key="L11"><span begin="00:33.750" end="00:33.930">吹</span><span begin="00:33.930" end="00:34.100">っ</span><span begin="00:34.100" end="00:34.240">飛</span><span begin="00:34.240" end="00:34.360">ん</span><span begin="00:34.360" end="00:34.590">で</span><span begin="00:34.590" end="00:34.790">ゆ</span><span begin="00:34.790" end="00:35.060">け</span><span ttm:role="x-translation" xml:lang="zh-CN">飞舞而去吧</span><span ttm:role="x-roman">Futtonde yuke</span></p>
      <p begin="00:35.080" end="00:36.330" ttm:agent="v1" itunes:key="L12"><span begin="00:35.080" end="00:35.200">吹</span><span begin="00:35.200" end="00:35.310">っ</span><span begin="00:35.310" end="00:35.440">飛</span><span begin="00:35.440" end="00:35.630">ば</span><span begin="00:35.630" end="00:35.720">し</span><span begin="00:35.720" end="00:35.940">て</span><span begin="00:35.940" end="00:36.140">ゆ</span><span begin="00:36.140" end="00:36.330">け</span><span ttm:role="x-translation" xml:lang="zh-CN">吹飞而去吧</span><span ttm:role="x-roman">Futtobashite yuke</span></p>
      <p begin="00:36.820" end="00:37.960" ttm:agent="v1" itunes:key="L13"><span begin="00:36.820" end="00:37.010">駆</span><span begin="00:37.010" end="00:37.200">け</span><span begin="00:37.200" end="00:37.340">抜</span><span begin="00:37.340" end="00:37.520">け</span><span begin="00:37.520" end="00:37.670">て</span><span begin="00:37.670" end="00:37.860">ゆ</span><span begin="00:37.860" end="00:37.960">け</span><span ttm:role="x-translation" xml:lang="zh-CN">奔跑穿梭而去吧</span><span ttm:role="x-roman">Kakenukete yuke</span></p>
      <p begin="00:38.010" end="00:40.130" ttm:agent="v1" itunes:key="L14"><span begin="00:38.010" end="00:38.540">君</span><span begin="00:38.540" end="00:38.870">の</span><span begin="00:38.870" end="00:39.560">元</span><span begin="00:39.560" end="00:39.770">ま</span><span begin="00:39.770" end="00:40.130">で</span><span ttm:role="x-translation" xml:lang="zh-CN">直到你的身边</span><span ttm:role="x-roman">Kimi no moto made</span></p>
      <p begin="00:41.900" end="00:43.530" ttm:agent="v1" itunes:key="L15"><span begin="00:41.900" end="00:43.530">嗚呼</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊</span><span ttm:role="x-roman">Aa</span></p>
      <p begin="00:44.470" end="00:47.260" ttm:agent="v1" itunes:key="L16"><span begin="00:44.470" end="00:44.680">そ</span><span begin="00:44.680" end="00:44.850">の</span><span begin="00:44.850" end="00:45.000">目</span><span begin="00:45.000" end="00:45.200">か</span><span begin="00:45.200" end="00:45.350">っ</span><span begin="00:45.350" end="00:45.540">ぽ</span><span begin="00:45.540" end="00:45.720">じ</span><span begin="00:45.720" end="00:45.870">っ</span><span begin="00:45.870" end="00:46.040">て</span><span begin="00:46.040" end="00:46.200">気</span><span begin="00:46.200" end="00:46.510">づ</span><span begin="00:46.510" end="00:46.730">い</span><span begin="00:46.730" end="00:46.910">た</span><span begin="00:46.910" end="00:47.260">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">如果你睁大眼睛察觉到了的话</span><span ttm:role="x-roman">Sono me kappojitte kizuitara</span></p>
      <p begin="00:47.580" end="00:50.790" ttm:agent="v1" itunes:key="L17"><span begin="00:47.580" end="00:48.090">心</span><span begin="00:48.090" end="00:48.240">の</span><span begin="00:48.240" end="00:48.560">内</span><span begin="00:48.560" end="00:48.730">を</span><span begin="00:48.730" end="00:49.080">荒</span><span begin="00:49.080" end="00:49.290">ん</span><span begin="00:49.290" end="00:49.400">で</span><span begin="00:49.590" end="00:49.940">探</span><span begin="00:49.940" end="00:50.140">っ</span><span begin="00:50.140" end="00:50.300">て</span><span begin="00:50.300" end="00:50.470">み</span><span begin="00:50.470" end="00:50.640">て</span><span begin="00:50.640" end="00:50.790">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">就试着在荒芜的内心深处探寻吧</span><span ttm:role="x-roman">Kokoro no uchi o susande sagutte mite yo</span></p>
      <p begin="00:51.000" end="00:52.160" ttm:agent="v1" itunes:key="L18"><span begin="00:51.000" end="00:51.170">飛</span><span begin="00:51.170" end="00:51.360">ば</span><span begin="00:51.360" end="00:51.510">し</span><span begin="00:51.510" end="00:51.660">て</span><span begin="00:51.660" end="00:51.840">み</span><span begin="00:51.840" end="00:52.030">て</span><span begin="00:52.030" end="00:52.160">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">试着让它飞翔吧</span><span ttm:role="x-roman">Tobashite mite yo</span></p>
      <p begin="00:52.330" end="00:54.890" ttm:agent="v1" itunes:key="L19"><span begin="00:52.330" end="00:52.530">そ</span><span begin="00:52.530" end="00:52.710">の</span><span begin="00:52.710" end="00:53.040">電</span><span begin="00:53.040" end="00:53.110">波</span><span begin="00:53.110" end="00:53.200">思</span><span begin="00:53.200" end="00:53.560">考</span><span begin="00:53.560" end="00:53.710">で</span><span begin="00:53.710" end="00:54.060">届</span><span begin="00:54.060" end="00:54.220">い</span><span begin="00:54.220" end="00:54.410">て</span><span begin="00:54.410" end="00:54.560">み</span><span begin="00:54.560" end="00:54.720">て</span><span begin="00:54.720" end="00:54.890">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">试着用那电波思考传达过来吧</span><span ttm:role="x-roman">Sono denpa shikou de todoite mite yo</span></p>
      <p begin="00:55.090" end="00:57.520" ttm:agent="v1" itunes:key="L20"><span begin="00:55.090" end="00:55.250">で</span><span begin="00:55.250" end="00:55.440">き</span><span begin="00:55.440" end="00:55.590">る</span><span begin="00:55.590" end="00:55.770">な</span><span begin="00:55.770" end="00:55.920">ら</span><span begin="00:55.920" end="00:56.290">今</span><span begin="00:56.290" end="00:56.450">も</span><span begin="00:56.450" end="00:56.780">笑</span><span begin="00:56.780" end="00:56.950">っ</span><span begin="00:56.950" end="00:57.300">て</span><span begin="00:57.300" end="00:57.520">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">如果可以的话现在也笑一笑吧</span><span ttm:role="x-roman">Dekiru nara ima mo waratte yo</span></p>
      <p begin="00:57.800" end="01:00.330" ttm:agent="v1" itunes:key="L21"><span begin="00:57.800" end="00:57.960">で</span><span begin="00:57.960" end="00:58.140">き</span><span begin="00:58.140" end="00:58.300">る</span><span begin="00:58.300" end="00:58.450">な</span><span begin="00:58.450" end="00:58.660">ら</span><span begin="00:58.660" end="00:58.830">記</span><span begin="00:58.830" end="00:59.170">号</span><span begin="00:59.170" end="00:59.330">ば</span><span begin="00:59.330" end="00:59.520">か</span><span begin="00:59.520" end="00:59.700">り</span><span begin="00:59.700" end="01:00.040">で</span><span begin="01:00.040" end="01:00.330">も</span><span ttm:role="x-translation" xml:lang="zh-CN">如果可以的话即使全是符号</span><span ttm:role="x-roman">Dekiru nara kigou bakari demo</span></p>
      <p begin="01:00.530" end="01:01.680" ttm:agent="v1" itunes:key="L22"><span begin="01:00.530" end="01:00.850">歌</span><span begin="01:00.850" end="01:01.040">っ</span><span begin="01:01.040" end="01:01.220">て</span><span begin="01:01.220" end="01:01.380">み</span><span begin="01:01.380" end="01:01.540">て</span><span begin="01:01.540" end="01:01.680">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">也试着歌唱吧</span><span ttm:role="x-roman">Utatte mite yo</span></p>
      <p begin="01:01.910" end="01:03.750" ttm:agent="v1" itunes:key="L23"><span begin="01:01.910" end="01:02.240">笑</span><span begin="01:02.240" end="01:02.400">っ</span><span begin="01:02.400" end="01:02.590">て</span><span begin="01:02.590" end="01:02.730">み</span><span begin="01:02.730" end="01:03.250">せ</span><span begin="01:03.250" end="01:03.470">て</span><span begin="01:03.470" end="01:03.750">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">试着笑给我看吧</span><span ttm:role="x-roman">Waratte misete yo</span></p>
      <p begin="01:04.070" end="01:07.650" ttm:agent="v1" itunes:key="L24"><span begin="01:04.070" end="01:04.460">愛</span><span begin="01:04.460" end="01:04.640">を</span><span begin="01:04.640" end="01:04.980">哀</span><span begin="01:04.980" end="01:05.170">を</span><span begin="01:05.170" end="01:05.490">逢</span><span begin="01:05.490" end="01:05.660">を</span><span begin="01:05.660" end="01:06.000">藍</span><span begin="01:06.000" end="01:06.170">に</span><span begin="01:06.170" end="01:06.510">今</span><span begin="01:06.510" end="01:06.630">は</span><span begin="01:06.630" end="01:06.850">染</span><span begin="01:06.850" end="01:07.000">ま</span><span begin="01:07.000" end="01:07.150">っ</span><span begin="01:07.150" end="01:07.310">て</span><span begin="01:07.310" end="01:07.510">ゆ</span><span begin="01:07.510" end="01:07.650">く</span><span ttm:role="x-translation" xml:lang="zh-CN">爱与哀与相逢 如今都染上了湛蓝</span><span ttm:role="x-roman">Ai o ai o ai o ai ni ima wa somatte yuku</span></p>
