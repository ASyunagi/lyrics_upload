      <p begin="02:58.630" end="03:02.200" ttm:agent="v1" itunes:key="L57"><span begin="02:58.630" end="02:59.020">愛</span><span begin="02:59.020" end="02:59.180">を</span><span begin="02:59.180" end="02:59.530">哀</span><span begin="02:59.530" end="02:59.700">を</span><span begin="02:59.700" end="03:00.030">逢</span><span begin="03:00.030" end="03:00.170">を</span><span begin="03:00.170" end="03:00.550">藍</span><span begin="03:00.550" end="03:00.700">に</span><span begin="03:00.700" end="03:01.000">今</span><span begin="03:01.000" end="03:01.180">は</span><span begin="03:01.180" end="03:01.410">染</span><span begin="03:01.410" end="03:01.570">ま</span><span begin="03:01.570" end="03:01.720">っ</span><span begin="03:01.720" end="03:01.880">て</span><span begin="03:01.880" end="03:02.060">ゆ</span><span begin="03:02.060" end="03:02.200">く</span><span ttm:role="x-translation" xml:lang="zh-CN">爱与哀与相逢 如今都染上了湛蓝</span><span ttm:role="x-roman">Ai o ai o ai o ai ni ima wa somatte yuku</span></p>
      <p begin="03:02.570" end="03:03.620" ttm:agent="v1" itunes:key="L58"><span begin="03:02.570" end="03:02.740">焦</span><span begin="03:02.740" end="03:02.920">が</span><span begin="03:02.920" end="03:03.090">し</span><span begin="03:03.090" end="03:03.250">て</span><span begin="03:03.250" end="03:03.440">ゆ</span><span begin="03:03.440" end="03:03.620">く</span><span ttm:role="x-translation" xml:lang="zh-CN">渐渐焦灼</span><span ttm:role="x-roman">Kogashite yuku</span></p>
      <p begin="03:03.890" end="03:06.270" ttm:agent="v1" itunes:key="L59"><span begin="03:03.890" end="03:04.100">そ</span><span begin="03:04.100" end="03:04.270">の</span><span begin="03:04.270" end="03:04.450">記</span><span begin="03:04.450" end="03:04.790">号</span><span begin="03:04.790" end="03:04.960">で</span><span begin="03:04.960" end="03:05.300">今</span><span begin="03:05.300" end="03:05.640">綴</span><span begin="03:05.640" end="03:05.820">っ</span><span begin="03:05.820" end="03:06.010">て</span><span begin="03:06.010" end="03:06.270">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">现在就用那符号拼凑吧</span><span ttm:role="x-roman">Sono kigou de ima tsuzutte yo</span></p>
      <p begin="03:06.670" end="03:14.940" ttm:agent="v1" itunes:key="L60"><span begin="03:06.670" end="03:07.000">何</span><span begin="03:07.000" end="03:07.170">も</span><span begin="03:07.170" end="03:07.370">か</span><span begin="03:07.370" end="03:07.520">も</span><span begin="03:07.520" end="03:07.870">全</span><span begin="03:07.870" end="03:08.030">部</span><span begin="03:08.030" end="03:08.360">届</span><span begin="03:08.360" end="03:08.450">い</span><span begin="03:08.880" end="03:09.580">て</span><span begin="03:09.580" end="03:14.940">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">把一切都传达过来吧</span><span ttm:role="x-roman">Nanimo kamo zenbu todoite yo</span></p>
