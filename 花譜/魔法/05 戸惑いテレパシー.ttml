  <body dur="03:14.470">
    <div begin="00:00.730" end="03:14.470">
      <p begin="00:00.730" end="00:03.360" ttm:agent="v1" itunes:key="L1"><span begin="00:00.730" end="00:00.810">絵</span><span begin="00:00.910" end="00:01.050">文</span><span begin="00:01.050" end="00:01.270">字</span><span begin="00:01.270" end="00:01.420">ば</span><span begin="00:01.420" end="00:01.600">か</span><span begin="00:01.600" end="00:01.770">り</span><span begin="00:01.770" end="00:01.960">で</span><span begin="00:01.960" end="00:02.460">頷</span><span begin="00:02.460" end="00:02.610">き</span><span begin="00:02.610" end="00:02.770">あ</span><span begin="00:02.770" end="00:02.920">お</span><span begin="00:02.920" end="00:03.160">う</span><span begin="00:03.160" end="00:03.360">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">就只用表情符号来互相点头附和吧</span><span ttm:role="x-roman">Emoji bakari de unazukiaou yo</span></p>
      <p begin="00:03.640" end="00:06.020" ttm:agent="v1" itunes:key="L2"><span begin="00:03.640" end="00:03.790">上</span><span begin="00:03.790" end="00:03.980">昇</span><span begin="00:03.980" end="00:04.150">中</span><span begin="00:04.150" end="00:04.250">の</span><span begin="00:04.250" end="00:04.340">記</span><span begin="00:04.340" end="00:04.510">号</span><span begin="00:04.510" end="00:04.690">が</span><span begin="00:04.840" end="00:05.020">今</span><span begin="00:05.020" end="00:05.170">も</span><span begin="00:05.170" end="00:05.350">鼓</span><span begin="00:05.350" end="00:05.450">動</span><span begin="00:05.450" end="00:05.590">を</span><span begin="00:05.590" end="00:05.680">止</span><span begin="00:05.680" end="00:05.760">め</span><span begin="00:05.760" end="00:05.850">る</span><span begin="00:05.850" end="00:06.020">の</span><span ttm:role="x-translation" xml:lang="zh-CN">正在上升的符号如今心也停止跳动了吗</span><span ttm:role="x-roman">Joushou chuu no kigou ga ima mo kodou o tomeru no</span></p>
      <p begin="00:06.360" end="00:08.610" ttm:agent="v1" itunes:key="L3"><span begin="00:06.360" end="00:06.700">単</span><span begin="00:06.700" end="00:07.060">純</span><span begin="00:07.060" end="00:07.230">だ</span><span begin="00:07.230" end="00:07.380">と</span><span begin="00:07.380" end="00:07.570">か</span><span begin="00:07.570" end="00:07.680">言</span><span begin="00:07.680" end="00:07.890">う</span><span begin="00:07.890" end="00:08.050">の</span><span begin="00:08.050" end="00:08.240">な</span><span begin="00:08.240" end="00:08.610">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">如果你要说这很简单的话</span><span ttm:role="x-roman">Tanjun da toka iu no nara</span></p>
      <p begin="00:08.900" end="00:11.460" ttm:agent="v1" itunes:key="L4"><span begin="00:08.900" end="00:09.220">今</span><span begin="00:09.220" end="00:09.440">す</span><span begin="00:09.440" end="00:09.560">ぐ</span><span begin="00:09.560" end="00:09.790">わ</span><span begin="00:09.790" end="00:09.960">か</span><span begin="00:09.960" end="00:10.120">り</span><span begin="00:10.120" end="00:10.280">や</span><span begin="00:10.280" end="00:10.470">す</span><span begin="00:10.470" end="00:10.570">く</span><span begin="00:10.570" end="00:10.940">教</span><span begin="00:10.940" end="00:11.150">え</span><span begin="00:11.150" end="00:11.310">て</span><span begin="00:11.310" end="00:11.460">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">现在立刻浅显易懂地告诉我吧</span><span ttm:role="x-roman">Ima sugu wakariyasuku oshiete yo</span></p>
      <p begin="00:11.810" end="00:13.390" ttm:agent="v1" itunes:key="L5"><span begin="00:11.810" end="00:12.160">今</span><span begin="00:12.160" end="00:12.490">何</span><span begin="00:12.490" end="00:12.680">し</span><span begin="00:12.680" end="00:12.850">て</span><span begin="00:12.850" end="00:13.020">ん</span><span begin="00:13.020" end="00:13.360">の</span><span begin="00:13.360" end="00:13.390">？</span><span ttm:role="x-translation" xml:lang="zh-CN">现在在做什么？</span><span ttm:role="x-roman">Ima nani shiten no?</span></p>
      <p begin="00:14.380" end="00:16.270" ttm:agent="v1" itunes:key="L6"><span begin="00:14.380" end="00:14.730">今</span><span begin="00:14.730" end="00:15.030">何</span><span begin="00:15.030" end="00:15.230">わ</span><span begin="00:15.230" end="00:15.380">か</span><span begin="00:15.380" end="00:15.570">っ</span><span begin="00:15.570" end="00:15.750">て</span><span begin="00:15.750" end="00:15.910">る</span><span begin="00:15.910" end="00:16.240">の</span><span begin="00:16.240" end="00:16.270">？</span><span ttm:role="x-translation" xml:lang="zh-CN">现在了解些什么？</span><span ttm:role="x-roman">Ima nani wakatteru no?</span></p>
      <p begin="00:16.400" end="00:18.990" ttm:agent="v1" itunes:key="L7"><span begin="00:16.400" end="00:16.590">わ</span><span begin="00:16.590" end="00:16.730">か</span><span begin="00:16.730" end="00:16.940">っ</span><span begin="00:16.940" end="00:17.130">て</span><span begin="00:17.130" end="00:17.300">る</span><span begin="00:17.300" end="00:17.470">な</span><span begin="00:17.470" end="00:17.570">ら</span><span begin="00:17.800" end="00:18.150">全</span><span begin="00:18.150" end="00:18.320">部</span><span begin="00:18.320" end="00:18.460">言</span><span begin="00:18.460" end="00:18.640">っ</span><span begin="00:18.640" end="00:18.820">て</span><span begin="00:18.820" end="00:18.990">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">如果了解的话就全部说出来吧</span><span ttm:role="x-roman">Wakatteru nara zenbu itte yo</span></p>
      <p begin="00:19.320" end="00:22.350" ttm:agent="v1" itunes:key="L8"><span begin="00:19.320" end="00:20.260">私</span><span begin="00:20.680" end="00:21.350">の</span><span begin="00:21.350" end="00:22.060">こ</span><span begin="00:22.060" end="00:22.350">と</span><span ttm:role="x-translation" xml:lang="zh-CN">关于我的事</span><span ttm:role="x-roman">Watashi no koto</span></p>
      <p begin="00:22.740" end="00:28.030" ttm:agent="v1" itunes:key="L9"><span begin="00:22.740" end="00:23.060">見</span><span begin="00:23.060" end="00:23.320">え</span><span begin="00:23.430" end="00:24.290">な</span><span begin="00:24.290" end="00:24.390">い</span><span begin="00:24.710" end="00:25.440">表</span><span begin="00:25.440" end="00:25.710">情</span><span begin="00:25.990" end="00:26.150">を</span><span begin="00:26.150" end="00:26.530">誤</span><span begin="00:26.660" end="00:26.820">魔</span><span begin="00:26.820" end="00:27.010">化</span><span begin="00:27.140" end="00:27.500">す</span><span begin="00:27.500" end="00:27.670">の</span><span begin="00:27.670" end="00:27.850">な</span><span begin="00:27.850" end="00:28.030">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">如果要掩饰看不见的表情的话</span><span ttm:role="x-roman">Mienai hyoujou o gomakasu no nara</span></p>
      <p begin="00:28.520" end="00:32.840" ttm:agent="v1" itunes:key="L10"><span begin="00:28.520" end="00:28.860">人</span><span begin="00:28.860" end="00:29.180">間</span><span begin="00:29.180" end="00:29.360">じゃ</span><span begin="00:29.360" end="00:29.570">な</span><span begin="00:29.570" end="00:29.680">い</span><span begin="00:29.680" end="00:29.880">っ</span><span begin="00:29.880" end="00:30.140">て</span><span begin="00:30.510" end="00:31.440">曝</span><span begin="00:31.440" end="00:31.610">け</span><span begin="00:31.610" end="00:32.050">出</span><span begin="00:32.050" end="00:32.270">し</span><span begin="00:32.270" end="00:32.520">ちゃ</span><span begin="00:32.520" end="00:32.640">う</span><span begin="00:32.640" end="00:32.840">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">我就会暴露自己不是人类哦</span><span ttm:role="x-roman">Ningen janai tte sarakedashichau yo</span></p>
      <p begin="00:33.280" end="00:34.590" ttm:agent="v1" itunes:key="L11"><span begin="00:33.280" end="00:33.460">吹</span><span begin="00:33.460" end="00:33.630">っ</span><span begin="00:33.630" end="00:33.770">飛</span><span begin="00:33.770" end="00:33.890">ん</span><span begin="00:33.890" end="00:34.120">で</span><span begin="00:34.120" end="00:34.320">ゆ</span><span begin="00:34.320" end="00:34.590">け</span><span ttm:role="x-translation" xml:lang="zh-CN">飞舞而去吧</span><span ttm:role="x-roman">Futtonde yuke</span></p>
      <p begin="00:34.610" end="00:35.860" ttm:agent="v1" itunes:key="L12"><span begin="00:34.610" end="00:34.730">吹</span><span begin="00:34.730" end="00:34.840">っ</span><span begin="00:34.840" end="00:34.970">飛</span><span begin="00:34.970" end="00:35.160">ば</span><span begin="00:35.160" end="00:35.250">し</span><span begin="00:35.250" end="00:35.470">て</span><span begin="00:35.470" end="00:35.670">ゆ</span><span begin="00:35.670" end="00:35.860">け</span><span ttm:role="x-translation" xml:lang="zh-CN">吹飞而去吧</span><span ttm:role="x-roman">Futtobashite yuke</span></p>
      <p begin="00:36.350" end="00:37.490" ttm:agent="v1" itunes:key="L13"><span begin="00:36.350" end="00:36.540">駆</span><span begin="00:36.540" end="00:36.730">け</span><span begin="00:36.730" end="00:36.870">抜</span><span begin="00:36.870" end="00:37.050">け</span><span begin="00:37.050" end="00:37.200">て</span><span begin="00:37.200" end="00:37.390">ゆ</span><span begin="00:37.390" end="00:37.490">け</span><span ttm:role="x-translation" xml:lang="zh-CN">奔跑穿梭而去吧</span><span ttm:role="x-roman">Kakenukete yuke</span></p>
      <p begin="00:37.540" end="00:39.660" ttm:agent="v1" itunes:key="L14"><span begin="00:37.540" end="00:38.070">君</span><span begin="00:38.070" end="00:38.400">の</span><span begin="00:38.400" end="00:39.090">元</span><span begin="00:39.090" end="00:39.300">ま</span><span begin="00:39.300" end="00:39.660">で</span><span ttm:role="x-translation" xml:lang="zh-CN">直到你的身边</span><span ttm:role="x-roman">Kimi no moto made</span></p>
      <p begin="00:41.430" end="00:43.060" ttm:agent="v1" itunes:key="L15"><span begin="00:41.430" end="00:43.060">嗚呼</span><span ttm:role="x-translation" xml:lang="zh-CN">啊啊</span><span ttm:role="x-roman">Aa</span></p>
      <p begin="00:44.000" end="00:46.790" ttm:agent="v1" itunes:key="L16"><span begin="00:44.000" end="00:44.210">そ</span><span begin="00:44.210" end="00:44.380">の</span><span begin="00:44.380" end="00:44.530">目</span><span begin="00:44.530" end="00:44.730">か</span><span begin="00:44.730" end="00:44.880">っ</span><span begin="00:44.880" end="00:45.070">ぽ</span><span begin="00:45.070" end="00:45.250">じ</span><span begin="00:45.250" end="00:45.400">っ</span><span begin="00:45.400" end="00:45.570">て</span><span begin="00:45.570" end="00:45.730">気</span><span begin="00:45.730" end="00:46.040">づ</span><span begin="00:46.040" end="00:46.260">い</span><span begin="00:46.260" end="00:46.440">た</span><span begin="00:46.440" end="00:46.790">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">如果你睁大眼睛察觉到了的话</span><span ttm:role="x-roman">Sono me kappojitte kizuitara</span></p>
      <p begin="00:47.110" end="00:50.320" ttm:agent="v1" itunes:key="L17"><span begin="00:47.110" end="00:47.620">心</span><span begin="00:47.620" end="00:47.770">の</span><span begin="00:47.770" end="00:48.090">内</span><span begin="00:48.090" end="00:48.260">を</span><span begin="00:48.260" end="00:48.610">荒</span><span begin="00:48.610" end="00:48.820">ん</span><span begin="00:48.820" end="00:48.930">で</span><span begin="00:49.120" end="00:49.470">探</span><span begin="00:49.470" end="00:49.670">っ</span><span begin="00:49.670" end="00:49.830">て</span><span begin="00:49.830" end="00:50.000">み</span><span begin="00:50.000" end="00:50.170">て</span><span begin="00:50.170" end="00:50.320">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">就试着在荒芜的内心深处探寻吧</span><span ttm:role="x-roman">Kokoro no uchi o susande sagutte mite yo</span></p>
      <p begin="00:50.530" end="00:51.690" ttm:agent="v1" itunes:key="L18"><span begin="00:50.530" end="00:50.700">飛</span><span begin="00:50.700" end="00:50.890">ば</span><span begin="00:50.890" end="00:51.040">し</span><span begin="00:51.040" end="00:51.190">て</span><span begin="00:51.190" end="00:51.370">み</span><span begin="00:51.370" end="00:51.560">て</span><span begin="00:51.560" end="00:51.690">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">试着让它飞翔吧</span><span ttm:role="x-roman">Tobashite mite yo</span></p>
      <p begin="00:51.860" end="00:54.420" ttm:agent="v1" itunes:key="L19"><span begin="00:51.860" end="00:52.060">そ</span><span begin="00:52.060" end="00:52.240">の</span><span begin="00:52.240" end="00:52.570">電</span><span begin="00:52.570" end="00:52.640">波</span><span begin="00:52.640" end="00:52.730">思</span><span begin="00:52.730" end="00:53.090">考</span><span begin="00:53.090" end="00:53.240">で</span><span begin="00:53.240" end="00:53.590">届</span><span begin="00:53.590" end="00:53.750">い</span><span begin="00:53.750" end="00:53.940">て</span><span begin="00:53.940" end="00:54.090">み</span><span begin="00:54.090" end="00:54.250">て</span><span begin="00:54.250" end="00:54.420">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">试着用那电波思考传达过来吧</span><span ttm:role="x-roman">Sono denpa shikou de todoite mite yo</span></p>
      <p begin="00:54.620" end="00:57.050" ttm:agent="v1" itunes:key="L20"><span begin="00:54.620" end="00:54.780">で</span><span begin="00:54.780" end="00:54.970">き</span><span begin="00:54.970" end="00:55.120">る</span><span begin="00:55.120" end="00:55.300">な</span><span begin="00:55.300" end="00:55.450">ら</span><span begin="00:55.450" end="00:55.820">今</span><span begin="00:55.820" end="00:55.980">も</span><span begin="00:55.980" end="00:56.310">笑</span><span begin="00:56.310" end="00:56.480">っ</span><span begin="00:56.480" end="00:56.830">て</span><span begin="00:56.830" end="00:57.050">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">如果可以的话现在也笑一笑吧</span><span ttm:role="x-roman">Dekiru nara ima mo waratte yo</span></p>
      <p begin="00:57.330" end="00:59.860" ttm:agent="v1" itunes:key="L21"><span begin="00:57.330" end="00:57.490">で</span><span begin="00:57.490" end="00:57.670">き</span><span begin="00:57.670" end="00:57.830">る</span><span begin="00:57.830" end="00:57.980">な</span><span begin="00:57.980" end="00:58.190">ら</span><span begin="00:58.190" end="00:58.360">記</span><span begin="00:58.360" end="00:58.700">号</span><span begin="00:58.700" end="00:58.860">ば</span><span begin="00:58.860" end="00:59.050">か</span><span begin="00:59.050" end="00:59.230">り</span><span begin="00:59.230" end="00:59.570">で</span><span begin="00:59.570" end="00:59.860">も</span><span ttm:role="x-translation" xml:lang="zh-CN">如果可以的话即使全是符号</span><span ttm:role="x-roman">Dekiru nara kigou bakari demo</span></p>
      <p begin="01:00.060" end="01:01.210" ttm:agent="v1" itunes:key="L22"><span begin="01:00.060" end="01:00.380">歌</span><span begin="01:00.380" end="01:00.570">っ</span><span begin="01:00.570" end="01:00.750">て</span><span begin="01:00.750" end="01:00.910">み</span><span begin="01:00.910" end="01:01.070">て</span><span begin="01:01.070" end="01:01.210">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">也试着歌唱吧</span><span ttm:role="x-roman">Utatte mite yo</span></p>
      <p begin="01:01.440" end="01:03.280" ttm:agent="v1" itunes:key="L23"><span begin="01:01.440" end="01:01.770">笑</span><span begin="01:01.770" end="01:01.930">っ</span><span begin="01:01.930" end="01:02.120">て</span><span begin="01:02.120" end="01:02.260">み</span><span begin="01:02.260" end="01:02.780">せ</span><span begin="01:02.780" end="01:03.000">て</span><span begin="01:03.000" end="01:03.280">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">试着笑给我看吧</span><span ttm:role="x-roman">Waratte misete yo</span></p>
      <p begin="01:03.600" end="01:07.180" ttm:agent="v1" itunes:key="L24"><span begin="01:03.600" end="01:03.990">愛</span><span begin="01:03.990" end="01:04.170">を</span><span begin="01:04.170" end="01:04.510">哀</span><span begin="01:04.510" end="01:04.700">を</span><span begin="01:04.700" end="01:05.020">逢</span><span begin="01:05.020" end="01:05.190">を</span><span begin="01:05.190" end="01:05.530">藍</span><span begin="01:05.530" end="01:05.700">に</span><span begin="01:05.700" end="01:06.040">今</span><span begin="01:06.040" end="01:06.160">は</span><span begin="01:06.160" end="01:06.380">染</span><span begin="01:06.380" end="01:06.530">ま</span><span begin="01:06.530" end="01:06.680">っ</span><span begin="01:06.680" end="01:06.840">て</span><span begin="01:06.840" end="01:07.040">ゆ</span><span begin="01:07.040" end="01:07.180">く</span><span ttm:role="x-translation" xml:lang="zh-CN">爱与哀与相逢 如今都染上了湛蓝</span><span ttm:role="x-roman">Ai o ai o ai o ai ni ima wa somatte yuku</span></p>
      <p begin="01:07.560" end="01:08.580" ttm:agent="v1" itunes:key="L25"><span begin="01:07.560" end="01:07.740">焦</span><span begin="01:07.740" end="01:07.930">が</span><span begin="01:07.930" end="01:08.090">し</span><span begin="01:08.090" end="01:08.220">て</span><span begin="01:08.220" end="01:08.440">ゆ</span><span begin="01:08.440" end="01:08.580">く</span><span ttm:role="x-translation" xml:lang="zh-CN">渐渐焦灼</span><span ttm:role="x-roman">Kogashite yuku</span></p>
      <p begin="01:08.900" end="01:11.350" ttm:agent="v1" itunes:key="L26"><span begin="01:08.900" end="01:09.110">そ</span><span begin="01:09.110" end="01:09.270">の</span><span begin="01:09.270" end="01:09.450">記</span><span begin="01:09.450" end="01:09.780">号</span><span begin="01:09.780" end="01:09.900">で</span><span begin="01:09.900" end="01:10.270">今</span><span begin="01:10.270" end="01:10.610">願</span><span begin="01:10.610" end="01:10.790">っ</span><span begin="01:10.790" end="01:10.950">て</span><span begin="01:10.950" end="01:11.350">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">现在就用那符号许愿吧</span><span ttm:role="x-roman">Sono kigou de ima negatte yo</span></p>
      <p begin="01:11.650" end="01:14.210" ttm:agent="v1" itunes:key="L27"><span begin="01:11.650" end="01:11.970">何</span><span begin="01:11.970" end="01:12.150">も</span><span begin="01:12.150" end="01:12.360">か</span><span begin="01:12.360" end="01:12.480">も</span><span begin="01:12.480" end="01:12.860">全</span><span begin="01:12.860" end="01:13.010">部</span><span begin="01:13.010" end="01:13.340">届</span><span begin="01:13.340" end="01:13.520">い</span><span begin="01:13.520" end="01:13.680">て</span><span begin="01:13.680" end="01:14.210">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">把一切都传达过来吧</span><span ttm:role="x-roman">Nanimo kamo zenbu todoite yo</span></p>
