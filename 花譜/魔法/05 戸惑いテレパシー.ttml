      <p begin="02:58.160" end="03:01.730" ttm:agent="v1" itunes:key="L57"><span begin="02:58.160" end="02:58.550">愛</span><span begin="02:58.550" end="02:58.710">を</span><span begin="02:58.710" end="02:59.060">哀</span><span begin="02:59.060" end="02:59.230">を</span><span begin="02:59.230" end="02:59.560">逢</span><span begin="02:59.560" end="02:59.700">を</span><span begin="02:59.700" end="03:00.080">藍</span><span begin="03:00.080" end="03:00.230">に</span><span begin="03:00.230" end="03:00.530">今</span><span begin="03:00.530" end="03:00.710">は</span><span begin="03:00.710" end="03:00.940">染</span><span begin="03:00.940" end="03:01.100">ま</span><span begin="03:01.100" end="03:01.250">っ</span><span begin="03:01.250" end="03:01.410">て</span><span begin="03:01.410" end="03:01.590">ゆ</span><span begin="03:01.590" end="03:01.730">く</span><span ttm:role="x-translation" xml:lang="zh-CN">爱与哀与相逢 如今都染上了湛蓝</span><span ttm:role="x-roman">Ai o ai o ai o ai ni ima wa somatte yuku</span></p>
      <p begin="03:02.100" end="03:03.150" ttm:agent="v1" itunes:key="L58"><span begin="03:02.100" end="03:02.270">焦</span><span begin="03:02.270" end="03:02.450">が</span><span begin="03:02.450" end="03:02.620">し</span><span begin="03:02.620" end="03:02.780">て</span><span begin="03:02.780" end="03:02.970">ゆ</span><span begin="03:02.970" end="03:03.150">く</span><span ttm:role="x-translation" xml:lang="zh-CN">渐渐焦灼</span><span ttm:role="x-roman">Kogashite yuku</span></p>
      <p begin="03:03.420" end="03:05.800" ttm:agent="v1" itunes:key="L59"><span begin="03:03.420" end="03:03.630">そ</span><span begin="03:03.630" end="03:03.800">の</span><span begin="03:03.800" end="03:03.980">記</span><span begin="03:03.980" end="03:04.320">号</span><span begin="03:04.320" end="03:04.490">で</span><span begin="03:04.490" end="03:04.830">今</span><span begin="03:04.830" end="03:05.170">綴</span><span begin="03:05.170" end="03:05.350">っ</span><span begin="03:05.350" end="03:05.540">て</span><span begin="03:05.540" end="03:05.800">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">现在就用那符号拼凑吧</span><span ttm:role="x-roman">Sono kigou de ima tsuzutte yo</span></p>
