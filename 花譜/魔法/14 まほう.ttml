      <p begin="02:44.100" end="02:46.500" ttm:agent="v1" itunes:key="L50"><span begin="02:44.100" end="02:44.760">叫</span><span begin="02:44.760" end="02:45.070">ぶ</span><span begin="02:45.070" end="02:45.380">か</span><span begin="02:45.380" end="02:45.600">ら</span><span begin="02:45.700" end="02:46.000">見</span><span begin="02:46.000" end="02:46.310">て</span><span begin="02:46.310" end="02:46.500">て</span><span ttm:role="x-translation" xml:lang="zh-CN">我会放声呐喊所以看着吧</span><span ttm:role="x-roman">Sakebu kara mitete</span></p>
      <p begin="02:46.560" end="02:46.850" ttm:agent="v1" itunes:key="L51"><span begin="02:46.560" end="02:46.730">そ</span><span begin="02:46.730" end="02:46.850">う</span><span ttm:role="x-translation" xml:lang="zh-CN">是的</span><span ttm:role="x-roman">Sou</span></p>
      <p begin="02:47.190" end="02:50.700" ttm:agent="v1" itunes:key="L52"><span begin="02:47.190" end="02:47.520">こ</span><span begin="02:47.520" end="02:47.820">れ</span><span begin="02:47.820" end="02:48.110">が</span><span begin="02:48.110" end="02:48.420">魔</span><span begin="02:48.420" end="02:50.700">法</span><span ttm:role="x-translation" xml:lang="zh-CN">这就是魔法</span><span ttm:role="x-roman">Kore ga mahou</span></p>
      <p begin="02:51.170" end="02:55.770" ttm:agent="v1" itunes:key="L53"><span begin="02:51.170" end="02:51.530">ら</span><span begin="02:51.530" end="02:51.800">ら</span><span begin="02:51.800" end="02:52.120">ら</span> <span begin="02:52.120" end="02:52.740">ら</span><span begin="02:52.740" end="02:53.050">ら</span> <span begin="02:53.050" end="02:53.660">ら</span><span begin="02:53.660" end="02:53.950">ら</span> <span begin="02:53.950" end="02:54.510">ら</span><span begin="02:54.510" end="02:54.830">ら</span><span begin="02:54.830" end="02:55.770">ら</span><span ttm:role="x-translation" xml:lang="zh-CN">啦啦啦 啦啦 啦啦 啦啦啦</span><span ttm:role="x-roman">Rarara rara rara rarara</span></p>
      <p begin="03:01.540" end="03:06.710" ttm:agent="v1" itunes:key="L54"><span begin="03:01.540" end="03:01.880">音</span><span begin="03:01.880" end="03:02.490">楽</span><span begin="03:02.490" end="03:02.780">は</span><span begin="03:02.780" end="03:03.120">魔</span><span begin="03:03.120" end="03:06.710">法</span><span ttm:role="x-translation" xml:lang="zh-CN">音乐即是魔法</span><span ttm:role="x-roman">Ongaku wa mahou</span></p>
