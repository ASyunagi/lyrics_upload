      <p begin="01:54.500" end="01:56.380" ttm:agent="v1" itunes:key="L33"><span begin="01:54.500" end="01:54.750">そ</span><span begin="01:54.750" end="01:54.890">れ</span><span begin="01:54.890" end="01:55.170">は</span><span begin="01:55.170" end="01:55.680">絆</span><span begin="01:55.680" end="01:55.830">だ</span><span begin="01:55.830" end="01:55.940">っ</span><span begin="01:55.940" end="01:56.120">た</span><span begin="01:56.120" end="01:56.380">り</span><span ttm:role="x-translation" xml:lang="zh-CN">那可能是羁绊</span><span ttm:role="x-roman">Sore wa kizuna dattari</span></p>
      <p begin="01:55.940" end="01:57.340" ttm:agent="v2" itunes:key="L34"><span begin="01:55.940" end="01:56.580">唇</span><span begin="01:56.580" end="01:56.740">だ</span><span begin="01:56.740" end="01:56.850">っ</span><span begin="01:56.850" end="01:57.000">た</span><span begin="01:57.000" end="01:57.340">り</span><span ttm:role="x-translation" xml:lang="zh-CN">可能是嘴唇</span><span ttm:role="x-roman">Kuchibiru dattari</span></p>
