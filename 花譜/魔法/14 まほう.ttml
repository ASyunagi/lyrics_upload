      <p begin="02:04.970" end="02:08.310" ttm:agent="v1" itunes:key="L38"><span begin="02:04.970" end="02:05.530">確</span><span begin="02:05.900" end="02:06.110">か</span><span begin="02:06.220" end="02:06.510">な</span><span begin="02:06.790" end="02:06.990">こ</span><span begin="02:07.130" end="02:07.430">と</span><span begin="02:07.430" end="02:07.730">な</span><span begin="02:07.730" end="02:08.040">ん</span><span begin="02:08.040" end="02:08.310">て</span><span ttm:role="x-translation" xml:lang="zh-CN">虽然确切的事物</span><span ttm:role="x-roman">Tashika na koto nante</span></p>
      <p begin="02:08.950" end="02:11.900" ttm:agent="v1" itunes:key="L39"><span begin="02:08.950" end="02:09.540">何</span><span begin="02:09.540" end="02:10.020">一</span><span begin="02:10.180" end="02:10.390">つ</span><span begin="02:10.510" end="02:10.820">な</span><span begin="02:10.820" end="02:11.280">い</span><span begin="02:11.380" end="02:11.720">け</span><span begin="02:11.720" end="02:11.900">ど</span><span ttm:role="x-translation" xml:lang="zh-CN">一件都没有</span><span ttm:role="x-roman">Nani hitotsu nai kedo</span></p>
      <p begin="02:12.320" end="02:15.540" ttm:agent="v1" itunes:key="L40"><span begin="02:12.320" end="02:12.510">勝</span><span begin="02:12.630" end="02:13.240">手</span><span begin="02:13.240" end="02:13.530">に</span><span begin="02:13.530" end="02:14.470">体</span><span begin="02:14.470" end="02:14.800">が</span><span begin="02:14.800" end="02:15.100">動</span><span begin="02:15.100" end="02:15.250">く</span><span begin="02:15.250" end="02:15.390">ん</span><span begin="02:15.390" end="02:15.540">だ</span><span ttm:role="x-translation" xml:lang="zh-CN">身体却自顾自地动了起来</span><span ttm:role="x-roman">Katte ni karada ga ugokunda</span></p>
      <p begin="02:15.930" end="02:19.890" ttm:agent="v1" itunes:key="L41"><span begin="02:15.930" end="02:16.310">や</span><span begin="02:16.310" end="02:16.600">り</span><span begin="02:16.600" end="02:17.200">残</span><span begin="02:17.200" end="02:17.530">し</span><span begin="02:17.530" end="02:17.840">た</span><span begin="02:17.840" end="02:18.150">こ</span><span begin="02:18.150" end="02:18.460">と</span><span begin="02:18.460" end="02:18.780">だ</span><span begin="02:18.780" end="02:19.070">ら</span><span begin="02:19.070" end="02:19.890">け</span><span ttm:role="x-translation" xml:lang="zh-CN">尽是些未竟之事</span><span ttm:role="x-roman">Yarinokoshita koto darake</span></p>
      <p begin="02:19.600" end="02:23.310" ttm:agent="v2" itunes:key="L42"><span begin="02:19.600" end="02:19.800">名</span><span begin="02:19.930" end="02:20.760">前</span><span begin="02:20.920" end="02:21.370">の</span><span begin="02:21.520" end="02:21.810">な</span><span begin="02:21.810" end="02:21.960">い</span><span begin="02:22.080" end="02:22.400">気</span><span begin="02:22.400" end="02:22.700">持</span><span begin="02:22.700" end="02:23.030">ち</span><span begin="02:23.030" end="02:23.310">が</span><span ttm:role="x-translation" xml:lang="zh-CN">没有名字的情感</span><span ttm:role="x-roman">Namae no nai kimochi ga</span></p>
      <p begin="02:23.640" end="02:26.690" ttm:agent="v2" itunes:key="L43"><span begin="02:23.640" end="02:24.270">籠</span><span begin="02:24.270" end="02:24.560">か</span><span begin="02:24.560" end="02:24.890">ら</span><span begin="02:24.890" end="02:25.190">出</span><span begin="02:25.190" end="02:25.510">た</span><span begin="02:25.510" end="02:25.930">が</span><span begin="02:25.930" end="02:26.100">っ</span><span begin="02:26.100" end="02:26.420">て</span><span begin="02:26.420" end="02:26.690">る</span><span ttm:role="x-translation" xml:lang="zh-CN">想要挣脱牢笼而出</span><span ttm:role="x-roman">Kago kara detagatteru</span></p>
      <p begin="02:26.990" end="02:30.480" ttm:agent="v2" itunes:key="L44"><span begin="02:26.990" end="02:27.330">自</span><span begin="02:27.330" end="02:27.960">分</span><span begin="02:27.960" end="02:28.220">に</span><span begin="02:28.220" end="02:28.860">嘘</span><span begin="02:28.860" end="02:29.170">は</span><span begin="02:29.170" end="02:29.320">も</span><span begin="02:29.320" end="02:29.520">う</span><span begin="02:29.520" end="02:29.660">つ</span><span begin="02:29.660" end="02:29.800">け</span><span begin="02:29.800" end="02:30.000">な</span><span begin="02:30.000" end="02:30.100">い</span><span begin="02:30.100" end="02:30.480">よ</span><span ttm:role="x-translation" xml:lang="zh-CN">已经无法再对自己说谎了哦</span><span ttm:role="x-roman">Jibun ni uso wa mou tsukenai yo</span></p>
      <p begin="02:30.980" end="02:32.740" ttm:agent="v1" itunes:key="L45"><span begin="02:30.980" end="02:31.300">馬</span><span begin="02:31.300" end="02:31.600">鹿</span><span begin="02:31.600" end="02:31.740">で</span><span begin="02:31.910" end="02:32.240">も</span><span begin="02:32.240" end="02:32.490">い</span><span begin="02:32.490" end="02:32.740">い</span><span ttm:role="x-translation" xml:lang="zh-CN">就算是笨蛋也没关系</span><span ttm:role="x-roman">Baka demo ii</span></p>
      <p begin="02:32.820" end="02:34.760" ttm:agent="v2" itunes:key="L46"><span begin="02:32.820" end="02:33.110">な</span><span begin="02:33.110" end="02:33.390">ら</span> <span begin="02:33.390" end="02:33.670">よ</span><span begin="02:33.670" end="02:33.900">う</span><span begin="02:34.000" end="02:34.210">こ</span><span begin="02:34.310" end="02:34.760">そ</span><span ttm:role="x-translation" xml:lang="zh-CN">那么 欢迎</span><span ttm:role="x-roman">Nara youkoso</span></p>
      <p begin="02:34.640" end="02:36.480" ttm:agent="v1" itunes:key="L47"><span begin="02:34.640" end="02:34.950">ぐ</span><span begin="02:34.950" end="02:35.290">ちゃ</span><span begin="02:35.290" end="02:35.550">ぐ</span><span begin="02:35.550" end="02:35.920">ちゃ</span><span begin="02:35.920" end="02:36.480">の</span><span ttm:role="x-translation" xml:lang="zh-CN">乱七八糟的</span><span ttm:role="x-roman">Guchagucha no</span></p>
      <p begin="02:36.500" end="02:38.160" ttm:agent="v2" itunes:key="L48"><span begin="02:36.500" end="02:36.840">ど</span><span begin="02:36.840" end="02:37.110">ろ</span><span begin="02:37.110" end="02:37.400">ど</span><span begin="02:37.400" end="02:37.730">ろ</span><span begin="02:37.730" end="02:38.160">の</span><span ttm:role="x-translation" xml:lang="zh-CN">泥泞不堪的</span><span ttm:role="x-roman">Dorodoro no</span></p>
